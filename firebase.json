{
  "hosting": {
    "public": "build/web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": [
    {
      "bucket": "rms-app-3d585.appspot.com",
      "rules": "storage.rules"
    }
  ],
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "rms-app-3d585",
          "appId": "1:1085944093717:android:83c3164e885742b42d421c",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "ios": {
        "default": {
          "projectId": "rms-app-3d585",
          "appId": "1:1085944093717:ios:43370b71e0f785532d421c",
          "uploadDebugSymbols": true,
          "fileOutput": "ios/Runner/GoogleService-Info.plist"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "rms-app-3d585",
          "configurations": {
            "android": "1:1085944093717:android:83c3164e885742b42d421c",
            "ios": "1:1085944093717:ios:43370b71e0f785532d421c",
            "macos": "1:1085944093717:ios:43370b71e0f785532d421c",
            "web": "1:1085944093717:web:ca6cafb339bb0a5e2d421c",
            "windows": "1:1085944093717:web:32d4cb19e56ae1572d421c"
          }
        }
      },
      "macos": {
        "default": {
          "projectId": "rms-app-3d585",
          "appId": "1:1085944093717:ios:43370b71e0f785532d421c",
          "uploadDebugSymbols": true,
          "fileOutput": "macos/Runner/GoogleService-Info.plist"
        }
      }
    }
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ]
}
